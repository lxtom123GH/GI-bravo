rules_version = '2';

// Storage for the portfolio identity hub. Per-user files (e.g. roast photos, once opted in)
// live under app/user-scoped paths; shared-space files under the space path. Mirrors the
// Firestore ownership model. Fail-closed: only the listed paths are writable.
service firebase.storage {
  match /b/{bucket}/o {

    // Private per-user files: apps/{appId}/users/{uid}/**
    match /apps/{appId}/users/{uid}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Shared-space files: apps/{appId}/spaces/{spaceId}/** — gated on Firestore membership.
    match /apps/{appId}/spaces/{spaceId}/{allPaths=**} {
      allow read: if request.auth != null &&
        firestore.exists(/databases/(default)/documents/apps/$(appId)/spaces/$(spaceId)/members/$(request.auth.uid));
      allow write: if request.auth != null &&
        firestore.get(/databases/(default)/documents/apps/$(appId)/spaces/$(spaceId)/members/$(request.auth.uid)).data.role in ['editor', 'owner'];
    }
  }
}
