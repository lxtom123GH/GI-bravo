# GI-bravo Firebase web config (the SHARED portfolio identity hub: project id "lx-apps").
# Copy to `.env` and paste the real values from the Firebase console
# (Project settings -> General -> Your apps -> Web app -> SDK setup and configuration).
# These web keys are NOT secrets (they ship in the client bundle), but keep `.env` out of git.
# When unset, the app runs against the LOCAL EMULATOR with placeholder values and no cloud.

VITE_FB_API_KEY=PLACEHOLDER_API_KEY
VITE_FB_AUTH_DOMAIN=lx-apps.firebaseapp.com
VITE_FB_PROJECT_ID=lx-apps
VITE_FB_STORAGE_BUCKET=lx-apps.appspot.com
VITE_FB_MESSAGING_SENDER_ID=PLACEHOLDER_SENDER_ID
VITE_FB_APP_ID=PLACEHOLDER_APP_ID

# Set to "1" to force the app to talk to the local Firebase emulators even off localhost.
VITE_FB_USE_EMULATOR=
